exports.handler = async (event) => {
  const { symbol, from, to } = event.queryStringParameters || {};
  if (!symbol) return { statusCode: 400, body: 'Missing symbol parameter' };

  const params = new URLSearchParams({ symbol, token: process.env.FINNHUB_TOKEN });
  if (from) params.append('from', from);
  if (to) params.append('to', to);

  const url = `https://finnhub.io/api/v1/company-news?${params.toString()}`;

  try {
    const res = await fetch(url);
    const data = await res.json();
    return {
      statusCode: 200,
      headers: { 'Access-Control-Allow-Origin': '*', 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    };
  } catch (err) {
    return { statusCode: 500, body: JSON.stringify({ error: err.message }) };
  }
};
